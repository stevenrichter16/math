    <div class="slope-display">
      <div class="slope-badge">Slope (derivative): <span id="slopeVal">&mdash;</span></div>
      <div class="slope-badge">f(x) = <span id="fxVal">&mdash;</span></div>
    </div>
  </div>
  <div id="desmos-container"></div>
